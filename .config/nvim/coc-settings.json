{
  "suggest.noselect": false,
  "coc.preferences.enableCompletion": true,
  "languageserver": {
    "jedi": {
      "command": "jedi-language-server",
      "filetypes": ["python"]
    },
    "rust": {
      "command": "rust-analyzer",
      "filetypes": ["rust"]
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": ["--stdio"],
      "filetypes": ["yaml", "yml"]
    }
  },
  "rust-analyzer": {
    "cargo": {
      "loadOutDirsFromCheck": true
    },
    "procMacro": {
      "enable": true
    }
  },
  "clangd": {
    "fallbackFlags": ["-std=c++17"]
  },
  "tsserver": {
    "formatOnSave": true
  },
  "html": {
    "formatOnSave": true
  },
  "css": {
    "formatOnSave": true
  },
  "json": {
    "formatOnSave": true
  },
  "yaml": {
    "formatOnSave": true
  }
}
