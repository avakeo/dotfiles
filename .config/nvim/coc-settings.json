{
  "suggest.noselect": false,
  "languageserver": {
    "rust": {
      "settings": {
        "rust-analyzer": {
          "editor.formatOnType": true,
          "editor.formatOnSave": true,
          "rustfmt.formatOnSave": true,
          "rustfmt.config": {
            "use_tabs": false,
            "tab_width": 2,
            "indent_style": "block"
          }
        }
      }
    },
    "jedi": {
      "enable": true,
      "startupMessage": false,
      "executable": {
        "command": "~/m3hoge/.anyenv/pyenv/neovim/bin/jedi-language-server"
      }
    }
  }
}

