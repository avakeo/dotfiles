# Chezmoi cross-platform configuration (templated)
# Detect OS and define common paths.

[data]
  # Home directory (explicit for clarity)
  home = "{{ .chezmoi.homeDir }}"

  # XDG config home (prefer provided, fallback to ~/.config)
  xdg_config_home = "{{ if .xdg.configHome }}{{ .xdg.configHome }}{{ else }}{{ .chezmoi.homeDir }}/.config{{ end }}"

  # Neovim config directory depending on OS
  nvim_config_dir = '{{ if eq .chezmoi.os "windows" }}{{ .chezmoi.homeDir }}/AppData/Local/nvim{{ else }}{{ if .xdg.configHome }}{{ .xdg.configHome }}{{ else }}{{ .chezmoi.homeDir }}/.config{{ end }}/nvim{{ end }}'

# Use {{ .nvim_config_dir }} in templates or scripts.
# Files under dot_config/nvim go to ~/.config/nvim (Linux/macOS).
# On Windows, a symlink to ~/.config/nvim is created at ~/AppData/Local/nvim.
